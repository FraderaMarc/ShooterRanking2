<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ShooterRanking2" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/sr_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/sr_primary_dark</item>
        <item name="colorOnPrimaryContainer">@android:color/white</item>

        <item name="colorSecondary">@color/sr_primary</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorSecondaryContainer">@color/sr_primary_dark</item>
        <item name="colorOnSecondaryContainer">@android:color/white</item>

        <item name="android:colorBackground">@color/sr_background</item>
        <item name="colorOnBackground">@color/sr_text</item>

        <item name="colorSurface">@color/sr_surface</item>
        <item name="colorOnSurface">@color/sr_text</item>
        <item name="colorSurfaceVariant">@color/sr_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/sr_text_secondary</item>

        <item name="colorError">@color/sr_error</item>
        <item name="colorOnError">@android:color/white</item>

        <item name="android:statusBarColor">@color/sr_background</item>
        <item name="android:navigationBarColor">@color/sr_background</item>
        <item name="android:windowBackground">@color/sr_background</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.ShooterRanking2.Dialog</item>
        <item name="materialCardViewStyle">@style/Widget.ShooterRanking2.Card</item>
    </style>

    <style name="ThemeOverlay.ShooterRanking2.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/sr_primary</item>
        <item name="colorSurface">@color/sr_surface</item>
        <item name="colorOnSurface">@color/sr_text</item>
        <item name="colorOnSurfaceVariant">@color/sr_text_secondary</item>
        <item name="colorOutline">@color/sr_surface_variant</item>
    </style>

    <style name="Widget.ShooterRanking2.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/sr_surface</item>
        <item name="strokeColor">@color/sr_surface_variant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>

</resources>